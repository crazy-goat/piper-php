{
    "name": "decodo/onnx-tts",
    "description": "PHP Text-to-Speech library using ONNX models via FFI",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-ffi": "*",
        "ext-mbstring": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "OnnxTTS\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OnnxTTS\\Tests\\": "tests/"
        }
    }
}
