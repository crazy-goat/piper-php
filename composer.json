{
    "name": "crazy-goat/piper-php",
    "description": "Text-to-speech in PHP using Piper via FFI",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-ffi": "*"
    },
    "autoload": {
        "psr-4": {
            "CrazyGoat\\PiperTTS\\": "src/"
        }
    },
    "bin": ["bin/piper-tts", "scripts/post-install.php"],
    "require-dev": {
        "phpunit/phpunit": "10.5.63",
        "squizlabs/php_codesniffer": "3.13.5",
        "slevomat/coding-standard": "8.22.1",
        "rector/rector": "2.3.9",
        "phpstan/phpstan": "2.1.45"
    },
    "scripts": {
        "post-install-cmd": "@install-libs",
        "post-update-cmd": "@install-libs",
        "install-libs": "php scripts/post-install.php",
        "lint": ["phpcs --standard=phpcs.xml.dist", "@rector", "@phpstan"],
        "lint:fix": ["@rector:fix", "phpcbf --standard=phpcs.xml.dist"],
        "phpstan": "phpstan analyse",
        "cs": "phpcs --standard=phpcs.xml.dist",
        "cs-fix": "phpcbf --standard=phpcs.xml.dist",
        "rector": "rector process --dry-run",
        "rector:fix": "rector process"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
