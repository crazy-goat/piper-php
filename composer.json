{
    "name": "crazy-goat/piper-php",
    "description": "Text-to-speech in PHP using Piper via FFI",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-ffi": "*"
    },
    "autoload": {
        "psr-4": {
            "CrazyGoat\\PiperTTS\\": "src/"
        }
    },
"bin": ["bin/piper-tts", "scripts/piper-install"],
    "scripts": {
        "lint": ["phpcs --standard=phpcs.xml.dist", "@rector", "@phpstan"],
        "lint:fix": ["@rector:fix", "phpcbf --standard=phpcs.xml.dist"],
        "phpstan": "phpstan analyse",
        "cs": "phpcs --standard=phpcs.xml.dist",
        "cs-fix": "phpcbf --standard=phpcs.xml.dist",
        "rector": "rector process --dry-run",
        "rector:fix": "rector process"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
